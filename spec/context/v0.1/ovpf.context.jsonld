{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "ovpf": "https://openvehiclepassport.org/ns/v0.1#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "id": "@id",
    "type": "@type",

    "//": "--- envelope terms ---",
    "specVersion": "ovpf:specVersion",
    "vehicle": { "@id": "ovpf:vehicle", "@type": "@id" },
    "occurredAt": { "@id": "ovpf:occurredAt", "@type": "xsd:dateTime" },
    "recordedAt": { "@id": "ovpf:recordedAt", "@type": "xsd:dateTime" },
    "producer": "ovpf:producer",
    "device": "ovpf:device",
    "operator": "ovpf:operator",
    "data": "ovpf:data",
    "corrects": { "@id": "ovpf:corrects", "@type": "@id" },
    "correctionReason": "ovpf:correctionReason",
    "prevHash": "ovpf:prevHash",
    "hash": "ovpf:hash",
    "attachments": "ovpf:attachments",
    "mediaType": "schema:encodingFormat",

    "//2": "--- vehicle description → Schema.org Vehicle ---",
    "Vehicle": "schema:Vehicle",
    "vin": "schema:vehicleIdentificationNumber",
    "make": "schema:brand",
    "model": "schema:model",
    "modelYear": { "@id": "schema:vehicleModelDate", "@type": "xsd:gYear" },
    "trim": "schema:vehicleConfiguration",
    "bodyType": "schema:bodyType",
    "driveType": "schema:driveWheelConfiguration",
    "doors": "schema:numberOfDoors",
    "fuelType": "schema:fuelType",
    "engine": "schema:vehicleEngine",
    "transmission": "schema:vehicleTransmission",
    "gears": "schema:numberOfForwardGears",
    "color": "schema:color",

    "//3": "--- generic reusable concepts ---",
    "odometer": { "@id": "schema:mileageFromOdometer", "@type": "@id" },
    "value": "schema:value",
    "unit": "schema:unitCode",
    "price": "schema:price",
    "currency": "schema:priceCurrency",
    "vendor": "schema:provider",
    "part": "schema:Product",
    "gtin": "schema:gtin",

    "//4": "--- OVPF-native domain concepts (no Schema.org equivalent) ---",
    "module": "ovpf:module",
    "codes": "ovpf:codes",
    "code": "ovpf:code",
    "status": "ovpf:status",
    "text": "ovpf:text",
    "rawHex": "ovpf:rawHex",
    "envHex": "ovpf:environmentHex",
    "channels": "ovpf:channels",
    "sampleRate": "ovpf:sampleRate",
    "before": "ovpf:codingBefore",
    "after": "ovpf:codingAfter",
    "preset": "ovpf:preset",
    "confidence": "ovpf:confidence",
    "basis": { "@id": "ovpf:basis", "@type": "@id" }
  }
}
